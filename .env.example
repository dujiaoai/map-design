# RuoYi API 代理目标（vite dev proxy /YunYanApi）
VITE_APP_BASE_HOST=https://www.airace.com.cn

# 本地 Java saas-api（services/saas-api :8082）
# 联调冒烟推荐 /v1（vite proxy）；直连 Java 用 http://localhost:8082
VITE_API_URL=/v1
# VITE_API_URL=http://localhost:8082
# VITE_SAAS_API_HOST=http://localhost:8082

# VITE_APP_URL=http://localhost:5175

# --- saas-api OIDC 本地联调（可选，默认关闭）---
# SAAS_OAUTH2_ENABLED=true
# SAAS_WEB_BASE_URL=http://localhost:5175
# SAAS_ADMIN_BASE_URL=http://localhost:5181
# SAAS_OAUTH2_KEYCLOAK_ISSUER_URI=http://localhost:8180/realms/yunyan
# SAAS_OAUTH2_KEYCLOAK_CLIENT_ID=saas-local
# SAAS_OAUTH2_KEYCLOAK_CLIENT_SECRET=

# --- Phase C 地图插件联调（packages-map，可选）---
# VITE_MAP_PLUGIN_LOADERS=true
# VITE_MAP_PLUGINS_BASE=@haoxuan/map-plugins
# VITE_MAP_ENGINE_READY=true
