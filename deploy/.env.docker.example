# docker compose 环境变量示例
# 用法：cp .env.docker.example .env

# 镜像标签
TAG=latest

# 构建模式：production | airace
BUILD_MODE=production

# RuoYi API 上游（saas-web Nginx 反代目标，不含 /YunYanApi 前缀）
RUOYI_API_UPSTREAM=https://www.airace.com.cn

# saas-api / billing-api 共用 JWT（docker profile）
SAAS_JWT_SECRET=docker-only-change-me-use-32chars-min!!

# 宿主机映射端口
SAAS_WEB_PORT=8084
SAAS_ADMIN_PORT=8083
SAAS_API_PORT=8082
# billing-api 直连调试端口（勿与 SAAS_ADMIN_PORT 冲突；经 Nginx 访问 /v1/billing 时可不映射）
BILLING_API_PORT=8085
CLOUD_UAV_PORT=8081
GATEWAY_PORT=9080

# --- billing-api ↔ saas-api 内网 m2m（两服务须一致）---
BILLING_INTERNAL_TOKEN=docker-billing-internal-token-change-me
SAAS_BILLING_ENABLED=true
SAAS_BILLING_API_BASE_URL=http://billing-api:8083

# --- billing-api Webhook（支付渠道回调 /v1/billing/webhooks/*）---
# 骨架 Token；生产即使开启验签也建议保留
BILLING_WEBHOOK_TOKEN=docker-billing-webhook-token-change-me
# 生产 true；本地 compose 默认 false（仅 Token）
BILLING_WEBHOOK_SIGNATURE_VERIFY_ENABLED=false
# hmac | wechat_v3 | alipay_rsa
BILLING_WEBHOOK_WECHAT_SIGNATURE_MODE=hmac
BILLING_WEBHOOK_ALIPAY_SIGNATURE_MODE=hmac
# HMAC 模式密钥（与渠道配置一致）
# BILLING_WEBHOOK_WECHAT_SIGN_SECRET=
# BILLING_WEBHOOK_ALIPAY_SIGN_SECRET=
# RSA 模式公钥 PEM（单行可用 \n 转义换行，或 docker secret 挂载）
# BILLING_WEBHOOK_WECHAT_PLATFORM_PUBLIC_KEY_PEM=
# BILLING_WEBHOOK_ALIPAY_PUBLIC_KEY_PEM=

# --- billing-api 运营开关 ---
# compose 演示默认 true；生产 false
BILLING_MOCK_PAYMENT=true
# stub | live（live 需配置下方微信/支付宝凭证）
BILLING_PAYMENT_PROVIDER_MODE=stub
# live 模式下回调丢失补偿查单（默认 false）
# BILLING_PAYMENT_QUERY_SCAN_ENABLED=false
# BILLING_PAYMENT_WECHAT_APP_ID=
# BILLING_PAYMENT_WECHAT_MCH_ID=
# BILLING_PAYMENT_WECHAT_API_V3_KEY=
# BILLING_PAYMENT_WECHAT_MERCHANT_SERIAL_NO=
# BILLING_PAYMENT_WECHAT_PRIVATE_KEY_PEM=
# BILLING_PAYMENT_WECHAT_APP_SECRET=
# BILLING_PAYMENT_ALIPAY_APP_ID=
# BILLING_PAYMENT_ALIPAY_PRIVATE_KEY_PEM=
# BILLING_PAYMENT_ALIPAY_PUBLIC_KEY_PEM=
# BILLING_PAYMENT_ALIPAY_NOTIFY_URL=
# BILLING_PAYMENT_ALIPAY_GATEWAY_URL=https://openapi.alipay.com/gateway.do
BILLING_RATE_LIMIT_ENABLED=true
BILLING_LOW_BALANCE_THRESHOLD=50
# 充值抵扣券叠加：single | stack（默认 single，每笔最多 1 张）
# BILLING_COUPON_STACKING_MODE=single
# BILLING_COUPON_MAX_PER_RECHARGE=1
# BILLING_COUPON_MIN_PAYABLE_CENTS=0
# BILLING_COUPON_BLOCK_CONCURRENT_PENDING=true

# 对公转账 — 平台收款账户（saas-web 展示；未配置时 enabled=false）
# BILLING_WIRE_TRANSFER_PLATFORM_ACCOUNT_ENABLED=true
# BILLING_WIRE_TRANSFER_PLATFORM_ACCOUNT_NAME=
# BILLING_WIRE_TRANSFER_PLATFORM_BANK_NAME=
# BILLING_WIRE_TRANSFER_PLATFORM_ACCOUNT_NO=
# BILLING_WIRE_TRANSFER_PLATFORM_TRANSFER_REMARK=

# --- billing-api 独立 PostgreSQL（可选，默认与 saas-api 共用 postgres/saas）---
# 启用：docker compose -f deploy/docker-compose.yml -f deploy/docker-compose.billing-db.yml up -d
# BILLING_DATASOURCE_URL=jdbc:postgresql://postgres-billing:5432/billing
# BILLING_DATASOURCE_USERNAME=billing
# BILLING_DATASOURCE_PASSWORD=billing
# BILLING_MEMBERSHIP_SYNC_ENABLED=true
# BILLING_MEMBERSHIP_SYNC_SOURCE=local
# BILLING_MEMBERSHIP_SAAS_API_BASE_URL=http://saas-api:8082
# BILLING_SAAS_DATASOURCE_URL=jdbc:postgresql://postgres:5432/saas
# BILLING_SAAS_DATASOURCE_USERNAME=saas
# BILLING_SAAS_DATASOURCE_PASSWORD=saas
