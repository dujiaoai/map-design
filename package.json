{
  "name": "@repo/saas",
  "version": "0.0.1",
  "private": true,
  "engines": {
    "node": ">=20.19.0",
    "pnpm": ">=9.14.0"
  },
  "description": "SaaS 产品线 workspace（Biome lint/format）",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "turbo run dev --filter=@repo/saas-web --filter=@repo/saas-admin",
    "dev:web": "pnpm --filter @repo/saas-web dev",
    "dev:admin": "pnpm --filter @repo/saas-admin dev",
    "dev:marketing": "pnpm --filter @repo/saas-marketing dev",
    "dev:web:airace": "pnpm --filter @repo/saas-web dev:airace",
    "dev:uav": "pnpm --filter @repo/cloud-uav dev",
    "build": "node scripts/turbo-run.mjs run build",
    "build:web": "node scripts/turbo-run.mjs run build --filter=@repo/saas-web",
    "build:web:airace": "node scripts/turbo-run.mjs run build:airace --filter=@repo/saas-web",
    "build:uav": "node scripts/turbo-run.mjs run build --filter=@repo/cloud-uav",
    "typecheck": "node scripts/turbo-run.mjs run typecheck",
    "test": "node scripts/turbo-run.mjs run test",
    "validate": "node scripts/turbo-run.mjs run typecheck && node scripts/turbo-run.mjs run test && pnpm check",
    "smoke:saas-api": "node services/saas-api/scripts/smoke-auth.mjs",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "turbo": "2.9.16"
  }
}
